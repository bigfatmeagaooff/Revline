<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Upload status strip -->
        <TextView
            android:id="@+id/uploadStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter_medium"
            android:gravity="center"
            android:padding="10dp"
            android:textColor="@color/bg_primary"
            android:textSize="13sp"
            android:visibility="gone"
            tools:background="@color/success"
            tools:text="✓ Saved to leaderboard"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/restoredNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter_regular"
            android:padding="12dp"
            android:text="@string/restored_note"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- Section 1: hero stat -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_card"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                style="@style/Text.Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.12"
                android:text="@string/label_top_speed"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/heroTopSpeed"
                style="@style/Text.Display"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/accent_red"
                android:textSize="96sp"
                tools:text="124" />

            <TextView
                style="@style/Text.Unit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/unit_kmh"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/heroDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/inter_regular"
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                tools:text="Mon 24 Jun · 3:19 PM" />

            <TextView
                android:id="@+id/heroMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                tools:text="16.3 km · 23 min" />
        </LinearLayout>

        <!-- Section 2: stats grid 2x3 (1dp dividers via parent bg) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:background="@color/divider"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <include
                    layout="@layout/cell_stat"
                    android:id="@+id/cellDistance"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="1dp" />

                <include
                    layout="@layout/cell_stat"
                    android:id="@+id/cellAvgSpeed"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <include
                    layout="@layout/cell_stat"
                    android:id="@+id/cellDuration"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="1dp" />

                <include
                    layout="@layout/cell_stat"
                    android:id="@+id/cellMovingTime"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <include
                    layout="@layout/cell_stat"
                    android:id="@+id/cellZeroHundred"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="1dp" />

                <include
                    layout="@layout/cell_stat"
                    android:id="@+id/cellPeakG"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />
            </LinearLayout>
        </LinearLayout>

        <!-- Predicted vs actual (optional) -->
        <TextView
            android:id="@+id/predictionDelta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter_medium"
            android:padding="16dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:visibility="gone"
            tools:text="Maps said 22 min — took 26 min (+4 min)"
            tools:visibility="visible" />

        <LinearLayout
            android:id="@+id/predictionEntry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                style="@style/Text.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/prediction_prompt"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/predictionLayout"
                    style="@style/Widget.Revline.TextInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:hint="@string/prediction_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/predictionInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/addPredictionButton"
                    style="@style/Widget.Revline.Button.Outline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/prediction_add" />
            </LinearLayout>
        </LinearLayout>

        <!-- Section 3: route map -->
        <FrameLayout
            android:id="@+id/routeSection"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:layout_marginTop="1dp"
            android:background="@color/bg_card">

            <org.osmdroid.views.MapView
                android:id="@+id/mapView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <TextView
                android:id="@+id/mapPlaceholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/inter_regular"
                android:text="@string/no_route_data"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Section 4: G-force (conditional) -->
        <LinearLayout
            android:id="@+id/gforceSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                style="@style/Text.Section"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_gforce_section"
                android:textColor="@color/text_secondary" />

            <com.revline.tracker.ui.GForceGraphView
                android:id="@+id/gforceGraph"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginTop="12dp"
                android:background="@color/bg_card" />

            <TextView
                android:id="@+id/hardestBrakingValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/inter_regular"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                tools:text="Hardest braking: 0.8 G" />
        </LinearLayout>

        <!-- Section 4b: comments (only for uploaded trips) -->
        <LinearLayout
            android:id="@+id/commentsSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="8dp"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/viewCommentsButton"
                style="@style/Widget.Revline.Button.Outline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_comment"
                android:text="@string/view_comments" />
        </LinearLayout>

        <!-- Section 5: actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/shareButton"
                style="@style/Widget.Revline.Button.Outline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/share" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/reuploadButton"
                style="@style/Widget.Revline.Button.OutlineRed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/reupload_button"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>
