<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/summary_title"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/restoredNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/restored_note"
            android:textSize="13sp"
            android:textStyle="italic"
            android:visibility="gone"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/uploadStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:textSize="13sp"
            android:visibility="gone"
            tools:text="Uploaded to leaderboard ✓"
            tools:visibility="visible" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/reuploadButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/reupload_button"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- Headline prediction delta -->
        <com.google.android.material.card.MaterialCardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/revline_red"
            app:cardCornerRadius="12dp">

            <TextView
                android:id="@+id/predictionDelta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="Maps said 22 min — took 26 min (+4 min)" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Optional post-drive Maps prediction (Phase 3.3). Hidden once set. -->
        <LinearLayout
            android:id="@+id/predictionEntry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/prediction_prompt"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/predictionLayout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:hint="@string/prediction_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/predictionInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/addPredictionButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/prediction_add" />
            </LinearLayout>
        </LinearLayout>

        <!-- Stats grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_distance"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/distanceValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    tools:text="12.40 km" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_duration"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/durationValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    tools:text="26.0 min" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_avg_speed"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/avgSpeedValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    tools:text="48 km/h" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_top_speed"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/topSpeedValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    tools:text="98 km/h" />
            </LinearLayout>
        </LinearLayout>

        <!-- Drive detail (Feature 3) -->
        <LinearLayout
            android:id="@+id/detailSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_detail_section"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/rowIdle"
                style="@style/DetailRow">

                <TextView style="@style/DetailLabel" android:text="@string/label_idle" />

                <TextView
                    android:id="@+id/idleValue"
                    style="@style/DetailValue"
                    tools:text="4m 12s" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowMovingAvg"
                style="@style/DetailRow">

                <TextView style="@style/DetailLabel" android:text="@string/label_moving_avg" />

                <TextView
                    android:id="@+id/movingAvgValue"
                    style="@style/DetailValue"
                    tools:text="52 km/h" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowZeroHundred"
                style="@style/DetailRow">

                <TextView style="@style/DetailLabel" android:text="@string/label_zero_hundred" />

                <TextView
                    android:id="@+id/zeroHundredValue"
                    style="@style/DetailValue"
                    tools:text="9.4 s" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowZeroSixty"
                style="@style/DetailRow">

                <TextView style="@style/DetailLabel" android:text="@string/label_zero_sixty" />

                <TextView
                    android:id="@+id/zeroSixtyValue"
                    style="@style/DetailValue"
                    tools:text="5.1 s" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowLongestStretch"
                style="@style/DetailRow">

                <TextView
                    android:id="@+id/longestStretchLabel"
                    style="@style/DetailLabel"
                    tools:text="Longest over 100 km/h" />

                <TextView
                    android:id="@+id/longestStretchValue"
                    style="@style/DetailValue"
                    tools:text="6.2 km" />
            </LinearLayout>
        </LinearLayout>

        <!-- G-Force -->
        <LinearLayout
            android:id="@+id/gforceSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_gforce_section"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_max_lateral"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/maxLateralValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="0.62 G" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_max_accel"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/maxAccelValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="0.45 G" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_max_braking"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/maxBrakingValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="0.71 G" />
                </LinearLayout>
            </LinearLayout>

            <com.revline.tracker.ui.GForceGraphView
                android:id="@+id/gforceGraph"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/gforce_legend"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/hardestBrakingValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="Hardest braking: -0.71 G at 12:34 into the drive" />
        </LinearLayout>

        <!-- Route map (speed-colored) -->
        <LinearLayout
            android:id="@+id/routeSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_route_section"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/route_legend"
                android:textSize="12sp" />

            <org.osmdroid.views.MapView
                android:id="@+id/mapView"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/mapPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:padding="24dp"
                android:gravity="center"
                android:text="@string/route_empty"
                android:textSize="14sp"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>
