<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ===== Typography ===== -->

    <!-- Big speed/rank numbers: Barlow Condensed Bold, tight tracking -->
    <style name="Text.Display" parent="">
        <item name="android:fontFamily">@font/barlow_condensed_bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <!-- Units (km/h, km, min, s, G) paired with a number -->
    <style name="Text.Unit" parent="">
        <item name="android:fontFamily">@font/barlow_condensed_regular</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <!-- Small all-caps stat labels -->
    <style name="Text.Label" parent="">
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <!-- Body label -->
    <style name="Text.Body" parent="">
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Section header (TODAY, G-FORCE, ACCOUNT...) -->
    <style name="Text.Section" parent="">
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.12</item>
    </style>

    <!-- App wordmark -->
    <style name="Text.Wordmark" parent="">
        <item name="android:fontFamily">@font/barlow_condensed_bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <!-- ===== Buttons ===== -->

    <style name="Widget.Revline.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:fontFamily">@font/barlow_condensed_bold</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="backgroundTint">@color/accent_red</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:minHeight">60dp</item>
    </style>

    <style name="Widget.Revline.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="strokeColor">#FF333333</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="Widget.Revline.Button.OutlineRed" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textColor">@color/accent_red</item>
        <item name="strokeColor">@color/accent_red</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- ===== Inputs ===== -->
    <style name="Widget.Revline.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/bg_elevated</item>
        <item name="boxStrokeColor">@color/accent_red</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
    </style>

    <!-- Tab labels -->
    <style name="TextAppearance.Revline.Tab" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:fontFamily">@font/barlow_condensed_bold</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- ===== Cards ===== -->
    <style name="Widget.Revline.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">0dp</item>
    </style>

</resources>
